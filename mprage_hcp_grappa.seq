# Format of extension lists:
# id type ref next_id
# next_id of 0 terminates the list
# Extension list is followed by extension specifications
[EXTENSIONS]
1 1 3 0
2 1 4 1
3 1 5 2
4 1 6 3
5 1 7 0
6 1 5 0
7 3 1 0
8 3 2 0
9 1 8 8
10 1 1 0
11 1 2 10
12 3 3 0
13 1 8 12
14 1 4 10
15 3 4 0
16 1 8 15

# Extension specification for setting labels:
# id set labelstring
extension LABELSET 1
1 1 REF
2 1 IMA
3 0 REF
4 0 IMA
5 0 LIN
6 1 NOISE
7 0 NOISE
8 0 PAR

# Extension specification for increasing labels:
# id inc labelstring
extension LABELINC 3
1 1 PAR
2 2 LIN
3 1 LIN
4 0 LIN

